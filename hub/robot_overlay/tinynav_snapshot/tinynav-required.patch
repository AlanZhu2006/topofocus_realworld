+# Check stream health.
+ros2 topic hz /camera/camera/infra1/image_rect_raw
+ros2 topic hz /camera/camera/infra2/image_rect_raw
+ros2 topic hz /camera/camera/depth/image_rect_raw
+ros2 topic hz /camera/camera/color/image_raw
