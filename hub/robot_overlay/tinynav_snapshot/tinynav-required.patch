+tmux capture-pane -pt tinynav_nav_auto:go2-bridge -S -200 | rg 'Move|Released|StopMove'
+
+===============================================================================
+8. RViz diagnostic layers
+===============================================================================
+
+# Default diagnostic RViz:
+#   /tinynav/docs/vis_with_global_map.rviz
+#
+# Important layers:
+#   Static Global Map          /mapping/static_occupancy_grid
+#   Map Keyframe Path          /mapping/map_keyframe_path
+#   Map Keyframes              /mapping/map_keyframe_markers
+#   Current Pose In Map        /mapping/current_pose_in_map
+#   Relocalization Successes   /map/relocalization
+#   Global Plan                /mapping/global_plan
+#   Local Trajectory           /planning/trajectory_path
+
+source /home/nvidia/twork/tinynav_setup.bash
+cd /home/nvidia/twork/tinynav
+
+# Start static map publisher.
+uv run python tool/static_occupancy_grid_publisher.py \
+  --tinynav-map-path /home/nvidia/twork/tinynav/output/latest_map \
+  --topic /mapping/static_occupancy_grid \
+  --frame-id world \
+  --z 0.0
+
+# Start saved map keyframe publisher.
+uv run python tool/map_keyframe_publisher.py \
+  --tinynav-map-path /home/nvidia/twork/tinynav/output/latest_map \
+  --frame-id world
+
+===============================================================================
+9. VNC and RViz
+===============================================================================
+
+# Current stable headless display:
+#   address: <jetson-lan-ip>:5901
+#   password: set locally with TINYNAV_VNC_PASSWORD; do not commit it
+#   display: :1
+#   server: TigerVNC
+#
+# The real GNOME :0 desktop is black when HDMI is disconnected. Use :1.
+
+export TINYNAV_VNC_PASSWORD='<private-vnc-password>'
+bash /home/nvidia/twork/tinynav/scripts/run_visible_vnc.sh
+vncserver -list
+ss -ltnp | rg ':5901|Xtigervnc'
+
+# Start RViz manually in VNC.
+source /home/nvidia/twork/tinynav_setup.bash
+cd /home/nvidia/twork/tinynav
+export DISPLAY=:1
+export XAUTHORITY=/home/nvidia/.Xauthority
+export QT_X11_NO_MITSHM=1
+export LIBGL_ALWAYS_SOFTWARE=1
+ros2 run rviz2 rviz2 -d /tinynav/docs/vis_with_global_map.rviz
+
+# Move RViz onscreen if openbox places it at the corner.
+DISPLAY=:1 XAUTHORITY=/home/nvidia/.Xauthority wmctrl -r RViz -e 0,0,0,1280,720
+
+# Screenshot from server side.
+DISPLAY=:1 XAUTHORITY=/home/nvidia/.Xauthority scrot /tmp/vnc_rviz.png
+file /tmp/vnc_rviz.png
+
+===============================================================================
+10. Unitree Go2 bridge and keyboard test
+===============================================================================
+
+# Wired Go2 network. The static IP command is temporary and disappears after
+# reboot. Do not run teleop and TinyNav navigation at the same time unless you
+# intentionally want multiple /cmd_vel publishers.
+
+sudo ip addr add 192.168.123.100/24 dev eth0 2>/dev/null || true
+sudo ip link set eth0 up
+ping -I eth0 -c 1 192.168.123.161
+
+# Start Go2 bridge in foreground.
+source /home/nvidia/twork/tinynav_setup.bash
+cd /home/nvidia/twork/tinynav
+export UNITREE_NET_IF=eth0
+export GO2_CMD_TOPIC=/cmd_vel
+export GO2_MAX_VX=0.45
+export GO2_MAX_VY=0.25
+export GO2_MAX_WZ=0.80
+export GO2_MIN_CMD_V=0.10
+export GO2_MIN_CMD_W=0.20
+export GO2_LOG_COMMANDS=true
+bash scripts/run_go2_cmd_bridge.sh
+
+# Keyboard teleop in another terminal.
+source /home/nvidia/twork/tinynav_setup.bash
+cd /home/nvidia/twork/tinynav
+bash scripts/run_keyboard_teleop.sh --topic /cmd_vel --linear-speed 0.30 --angular-speed 0.55
+
+# Controls:
+#   w/s       forward/backward
+#   q/e       strafe left/right
+#   a/d       turn left/right
+#   space/x   stop
+#   +/-       speed scale
+#   h         help
+#   Ctrl-C    stop and exit
+
+===============================================================================
+11. Stop and cleanup
+===============================================================================
+
+tmux kill-session -t tinynav_nav_auto
+tmux kill-session -t tinynav_usb3_camera
+tmux kill-session -t tinynav_auto_map_camera
+vncserver -kill :1
+
+# Runtime data is intentionally ignored by git:
+#   output/
+#   tinynav_temp_nav_auto/
+#   tinynav_db/
+#   tinynav_temp/
+#   *.db
+#   *.plan
+#   *.engine
