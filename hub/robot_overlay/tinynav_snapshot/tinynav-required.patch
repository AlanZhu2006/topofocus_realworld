+===============================================================================
+2. RealSense
+===============================================================================
+
+source /home/nvidia/twork/tinynav_setup.bash
+
+# Device, firmware, USB speed.
+rs-fw-update -l
+rs-enumerate-devices | rg -i 'name|serial|firmware|usb|product'
+lsusb -t
+
+# Start TinyNav RealSense profile.
+cd /home/nvidia/twork/tinynav
+bash scripts/run_realsense_sensor.sh
+
+# Equivalent launch arguments.
+ros2 launch realsense2_camera rs_launch.py \
+  initial_reset:=true \
+  tf_publish_rate:=1.0 \
+  publish_tf:=true \
+  enable_depth:=true \
+  enable_color:=true \
+  enable_infra1:=true \
+  enable_infra2:=true \
+  enable_gyro:=true \
+  enable_accel:=true \
+  unite_imu_method:=2 \
+  depth_module.depth_profile:=848x480x30 \
+  depth_module.infra_profile:=848x480x30 \
+  rgb_camera.color_profile:=848x480x30
