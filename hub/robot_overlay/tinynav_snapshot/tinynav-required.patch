diff --git a/tinynav/core/perception_health.py b/tinynav/core/perception_health.py
new file mode 100644
index 0000000000000000000000000000000000000000..3ff72f89a860c51baaffc238fdc580fbec9f496f
--- /dev/null
+++ b/tinynav/core/perception_health.py
@@ -0,0 +1,65 @@
+"""Pure, dependency-free health checks for TinyNav perception intervals."""
+from __future__ import annotations
+
+import math
+
+IMU_NOMINAL_PERIOD_S = 0.005
+IMU_MIN_COVERAGE_RATIO = 0.80
+IMU_MAX_SAMPLE_GAP_S = 0.05
+IMU_END_TOLERANCE_S = 0.01
+
+
+def reanchor_keyframe_queue(keyframes):
+    """Keep only the newest frame after rejecting an invalid IMU interval.
+
+    The newest frame was just created with an empty preintegrator.  Retaining
+    it as the next anchor prevents one historical sample gap from poisoning
+    every future interval while the current optimization remains fail-closed.
+    """
+    if not keyframes:
+        raise ValueError("cannot re-anchor an empty keyframe queue")
+    newest = keyframes[-1]
+    keyframes.clear()
+    keyframes.append(newest)
+    newest.latest_imu_timestamp = newest.timestamp
+    newest.imu_measurement_count = 0
+    newest.imu_max_gap_s = 0.0
+    return newest
+
+
+def summarize_imu_intervals(keyframes) -> list[dict]:
+    """Return auditable coverage metrics for every adjacent keyframe pair."""
+    intervals = []
+    for start, end in zip(keyframes[:-1], keyframes[1:]):
+        duration_s = end.timestamp - start.timestamp
+        expected_count = max(
+            1, int(round(duration_s / IMU_NOMINAL_PERIOD_S)))
+        coverage_ratio = start.imu_measurement_count / expected_count
+        end_error_s = abs(start.latest_imu_timestamp - end.timestamp)
+        reasons = []
+        if not math.isfinite(duration_s) or duration_s <= 0.0:
+            reasons.append("invalid_duration")
+        if start.imu_measurement_count < 2:
+            reasons.append("too_few_samples")
+        if not math.isfinite(coverage_ratio) or coverage_ratio < IMU_MIN_COVERAGE_RATIO:
+            reasons.append("low_sample_coverage")
+        if (
+            not math.isfinite(start.imu_max_gap_s)
+            or start.imu_max_gap_s > IMU_MAX_SAMPLE_GAP_S
+        ):
+            reasons.append("sample_gap")
+        if not math.isfinite(end_error_s) or end_error_s > IMU_END_TOLERANCE_S:
+            reasons.append("end_not_covered")
+        intervals.append({
+            "start_timestamp": start.timestamp,
+            "end_timestamp": end.timestamp,
+            "duration_s": duration_s,
+            "sample_count": start.imu_measurement_count,
+            "expected_count": expected_count,
+            "coverage_ratio": coverage_ratio,
