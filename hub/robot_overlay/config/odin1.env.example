# Install as /home/nyu/focus_sender_odin1/focus-odin1.env with mode 0600.
# Never commit the real token.
FOCUS_ROBOT_TOKEN=

FOCUS_HUB_BASE_URL=http://127.0.0.1:18089
FOCUS_ROBOT_ID=robot-1

# Current observed Odin/WSJ board calibration. Change BOTH values together
# after remounting the sensor, resetting either odometry origin, or producing a
# newer independently validated calibration artifact.
FOCUS_ODIN1_TRANSFORM_VERSION=yunji-odin1-board-20260722-v1
FOCUS_ODIN1_SHARED_TRANSFORM_FILE=/home/nyu/focus_sender_odin1/yunji_odin1_board_20260722_v1.json

# The preview endpoint is reached only through the loopback-bound SSH reverse
# tunnel. The sender reuses FOCUS_ROBOT_TOKEN unless a separate
# FOCUS_CAMERA_PREVIEW_TOKEN is set.
FOCUS_ODIN1_CAMERA_PREVIEW_URL=http://127.0.0.1:18766/camera/yunji
