# Install as /home/nyu/focus_sender_odin1/focus-odin1.env with mode 0600.
# Never commit the real token.
FOCUS_ROBOT_TOKEN=

FOCUS_HUB_BASE_URL=http://127.0.0.1:18089
FOCUS_ROBOT_ID=robot-1

# Local-only mapping definition. After a fresh Odin board calibration, change
# BOTH values to that artifact's exact identities before restarting the sender.
FOCUS_ODIN1_TRANSFORM_VERSION=yunji-odin1-local-odom-20260722-v1
FOCUS_ODIN1_SHARED_TRANSFORM_FILE=
