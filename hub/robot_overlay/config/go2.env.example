# Copy to go2.env on the Jetson and adjust paths only. Never put tokens here.
TINYNAV_WORKSPACE=/home/nvidia/twork
TINYNAV_ROOT=/home/nvidia/twork/tinynav
TINYNAV_PATCHED_ROOT=/home/nvidia/twork/tinynav-topofocus
TINYNAV_SETUP=/home/nvidia/twork/tinynav_setup.bash
TINYNAV_PYTHON=/home/nvidia/twork/tinynav/.venv/bin/python

FOCUS_REHEARSAL_SESSION=focus_live_rehearsal
FOCUS_ROBOT_STATE_DIR=/home/nvidia/.local/state/topofocus
FOCUS_REALSENSE_POWER_SERVICE=focus-realsense-power.service

# The Hub normally reaches this loopback endpoint through an SSH reverse
# tunnel. Authentication is loaded from a separate chmod-600 token file.
FOCUS_HUB_BASE_URL=http://127.0.0.1:18089
FOCUS_ROBOT_ID=robot-0
